{
  "name": "@the-agency/pi-tokenshrink",
  "version": "0.1.2",
  "description": "Reduce token usage of a Pi agent's conversation context using TokenShrink.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "npm run lint && node --experimental-transform-types --test index.test.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "*.ts",
    "!*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi",
    "pi-package",
    "tokenshrink",
    "agents",
    "llm",
    "tokens"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "dependencies": {
    "tokenshrink": "^2.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JoshMock/the-agency.git",
    "directory": "packages/tokenshrink"
  }
}
