{
  "name": "@the-agency/pi-hashline-edit",
  "version": "0.1.0",
  "description": "Pi extension providing hashline-based file reading and editing with staleness-checked line addressing.",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "npm run lint && node --experimental-transform-types --test hashline.test.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "*.ts",
    "!*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi",
    "pi-package",
    "tools",
    "agents",
    "llm"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "license": "MIT"
}
