{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "outDir": "dist",
    "declaration": true
  },
  "include": ["*.ts"],
  "exclude": ["*.test.ts"]
}
